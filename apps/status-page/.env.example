# Application
APP_URL=https://status.harbour.space
NODE_ENV=production
PORT=3000

# Database — Railway provides this automatically when a Postgres service is linked
DATABASE_URL=

# Auth
AUTH_SECRET=                          # generate with: openssl rand -base64 32
ADMIN_EMAILS=                         # comma-separated list of admin emails (whitelisted on first sign-in)

# Email — Resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=status@harbour.space
MAIL_FROM_NAME="Harbour.Space Status"

# Uptime Monitor agents — shared secret used to HMAC-verify probe payloads
# from agents reporting to /api/internal/probes. Same value as the agents'
# AGENT_SHARED_SECRET.
AGENT_SHARED_SECRET=

# Consensus / status decision (see docs/architecture.md)
PROBE_RESULT_WINDOW_SECONDS=120       # rolling window for status computation
AGENT_STALE_AFTER_SECONDS=300         # show "monitoring offline" banner after this

# Outbound integrations (optional)
SLACK_WEBHOOK_URL=                    # mirror every incident update to a channel
TELEGRAM_BOT_TOKEN=                   # send Major outages to the on-call group
TELEGRAM_CHAT_ID=

# Inbound webhooks (optional) — used by external monitoring to push incidents
WEBHOOK_SHARED_SECRET=                # protect /api/webhooks/incident

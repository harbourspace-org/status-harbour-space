# Where to report results (the central Status Page)
STATUS_PAGE_URL=https://status.harbour.space

# Identity — must be unique per agent. Used by the consensus logic on the Status Page.
AGENT_ID=                       # e.g. railway-eu, internal-eu-1, internal-latam-1
AGENT_REGION=                   # e.g. eu, latam, us-east

# Shared secret used to HMAC-sign probe payloads.
# Must match `AGENT_SHARED_SECRET` set on the Status Page.
AGENT_SHARED_SECRET=

# Probe behaviour
PROBE_INTERVAL_SECONDS=60       # how often to probe every component
PROBE_TIMEOUT_MS=5000           # request timeout per probe

# Heartbeat
HEARTBEAT_INTERVAL_SECONDS=30   # how often to ping /api/internal/heartbeat

{
  "name": "uptime-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Harbour.Space uptime monitor agent. Probes components and reports to the central Status Page from multiple zones.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

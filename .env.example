# Application
APP_NAME="Harbour.Space Status"
APP_ENV=production
APP_KEY=                              # generate with: docker compose exec app php artisan key:generate
APP_DEBUG=false
APP_URL=https://status.harbour.space
APP_TIMEZONE=Europe/Madrid
APP_LOCALE=en

# Database (Postgres)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cachet
DB_USERNAME=cachet
DB_PASSWORD=                          # set a strong password before bringing the stack up

# Cache & queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Mail (for subscriber notifications)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=status@harbour.space
MAIL_FROM_NAME="Harbour.Space Status"

# Cachet
CACHET_BEACON=false                   # disable telemetry to Cachet servers
CACHET_EMOJI=false
CACHET_AUTO_TWITTER=false

# External integrations (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring (UptimeRobot or Better Stack pushes incidents via API)
MONITORING_API_KEY=

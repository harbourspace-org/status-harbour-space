# Application
APP_ENV=production
APP_KEY=                              # generate one strong base64 key, e.g. base64:$(openssl rand -base64 32)
APP_DEBUG=false
APP_URL=https://status.harbour.space

# Database (Postgres) — must match POSTGRES_* in docker-compose.yml
DB_DATABASE=cachet
DB_USERNAME=cachet
DB_PASSWORD=                          # set a strong password before bringing the stack up

# Mail (for subscriber notifications)
# Cachet 2.x uses MAIL_DRIVER (smtp / log / sendmail / mailgun)
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_ADDRESS=status@harbour.space
MAIL_NAME="Harbour.Space Status"

# External integrations (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring (UptimeRobot or Better Stack pushes incidents via API)
MONITORING_API_KEY=
